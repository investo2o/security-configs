{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(./.env.development)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./config/secrets.*)",
      "Read(./**/*secret*)",
      "Read(./**/*apikey*)",
      "Read(./**/*api_key*)",
      "Read(./**/*password*)",
      "Read(./**/*credential*)",
      "Read(./**/*token*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/*.jks)",
      "Read(./**/*.keystore)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/config)",
      "Read(./**/terraform.tfvars)",
      "Read(./**/*.tfstate)",
      "Read(./**/*.tfstate.backup)"
    ]
  }
}
